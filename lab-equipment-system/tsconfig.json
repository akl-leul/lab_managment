{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true, 
    "strict": true,
    "noEmit": true, 
    "module": "CommonJS",        
    "moduleResolution": "node",
    "esModuleInterop": true,
     "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,  
    "resolveJsonModule": true, 
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["node"],               // Correct usage instead of "type"
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "prisma/**/*.ts",
    "prisma/**/*.ts", "src/**/*.ts", "src/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
