generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Equipment {
  id          String   @id @default(cuid())
  name        String
  description String?
  quantity    Int
  status      String   @default("Available")
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String   @unique
  role         Role     @default(VIEWER)
  profileImage String?  // optional profile image URL or filename
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
model Announcement {
  id      String   @id @default(cuid())
  title   String
  message String
  date    DateTime
}



enum Role {
  SUPER_ADMIN
  ADMIN
  VIEWER
}
